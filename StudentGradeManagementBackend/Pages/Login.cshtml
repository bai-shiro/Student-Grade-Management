@page
@model StudentGradeManagementBackend.Pages.LoginModel
@{
    ViewData["Title"] = "ЕЧТМ";
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale = 1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body>
    <h1>бЇЩњГЩМЈЙмРэЯЕЭГ - ЕЧТМ</h1>
    <div class="card" style="width: 300px; margin: 20px auto;">
        <div class="card-body">
            @if (!string.IsNullOrEmpty(ViewData["Error"] as string))
            {
                <div class="alert alert-danger">@ViewData["Error"]</div>
            }
            <form method="post">
                <div class="form-group">
                    <label>еЫКХ</label>
                    <input type="text" class="form-control" name="UserId" required>
                </div>
                <div class="form-group">
                    <label>УмТы</label>
                    <input type="password" class="form-control" name="Password" required>
                </div>
                <button type="submit" class="btn btn-primary btn-block">ЕЧТМ</button>
            </form>
        </div>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>