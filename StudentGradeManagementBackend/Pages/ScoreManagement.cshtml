@page
@model StudentGradeManagementBackend.Pages.ScoreManagementModel
@{
    ViewData["Title"] = "ГЩМЈЙмРэ";
    // ЮДЕЧТМгУЛЇЬјзЊЕЧТМвГ
    if (string.IsNullOrWhiteSpace(Model.CurrentUserId) || string.IsNullOrWhiteSpace(Model.CurrentUserRole))
    {
        Response.Redirect("/Login");
    }
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <!-- Bootstrap 5 бљЪН -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Bootstrap 5 НХБО -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <!-- ЕМКНРИ -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="#">бЇЩњГЩМЈЙмРэЯЕЭГ</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" 
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/Index">ЪзвГ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="StudentManagement">бЇЩњЙмРэ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="CourseManagement">ПЮГЬЙмРэ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="#">ГЩМЈЙмРэ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="UserManagement">гУЛЇЙмРэ</a>
                    </li>
                </ul>
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <span class="nav-link text-light">ЕБЧАЕЧТМЃК@Model.CurrentUserId (@Model.CurrentUserRole)</span>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-light" href="/Login?logout=true">ЭЫГіЕЧТМ</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- жїФкШнЧј -->
    <div class="container mt-4">
        <h1 class="text-center mb-4">
            @(Model.CurrentUserRole == "admin" ? "ГЩМЈЙмРэЃЈЙмРэдБЃЉ" : "ЮвЕФГЩМЈЃЈбЇЩњЃЉ")
        </h1>

        <!-- ЙмРэдБЯдЪОЬэМгГЩМЈАДХЅ -->
        @if (Model.CurrentUserRole == "admin")
        {
            <button type="button" class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#addScoreModal">
                ЬэМгГЩМЈ
            </button>
        }

        <!-- ГЩМЈСаБэБэИё -->
        <div class="table-responsive">
            <table class="table table-striped table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ГЩМЈID</th>
                        <th>бЇЩњбЇКХ</th>
                        <th>бЇЩњаеУћ</th>
                        <th>ПЮГЬБрКХ</th>
                        <th>ПЮГЬУћГЦ</th>
                        <th>ГЩМЈ</th>
                        @if (Model.CurrentUserRole == "admin")
                        {
                            <th>Вйзї</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Scores != null && Model.Scores.Count > 0)
                    {
                        @foreach (var score in Model.Scores)
                        {
                            <!-- ЛёШЁбЇЩњаеУћ -->
                            var student = Model.Students?.FirstOrDefault(s => s.StudentId == score.StudentId);
                            var studentName = student?.Name ?? "ЮДжЊбЇЩњ";
                            
                            <!-- ЛёШЁПЮГЬУћГЦ -->
                            var course = Model.Courses?.FirstOrDefault(c => c.CourseId == score.CourseId);
                            var courseName = course?.CourseName ?? "ЮДжЊПЮГЬ";

                            <tr>
                                <td>@score.Id</td>
                                <td>@score.StudentId</td>
                                <td>@studentName</td>
                                <td>@score.CourseId</td>
                                <td>@courseName</td>
                                <td>@score.ScoreValue.ToString("0.00")</td>
                                @if (Model.CurrentUserRole == "admin")
                                {
                                    <td>
                                        <!-- БрМ­АДХЅЃКНіДЋЕнIDКЭГЩМЈжЕЃЌВЛвРРЕбЇЩњ/ПЮГЬID -->
                                        <button type="button" class="btn btn-primary btn-sm me-2"
                                                onclick="openEditModal(@score.Id, @score.ScoreValue)">
                                            БрМ­
                                        </button>
                                        <!-- ЩОГ§АДХЅ -->
                                        <button type="button" class="btn btn-danger btn-sm"
                                                onclick="deleteScore(@score.Id)">
                                            ЩОГ§
                                        </button>
                                    </td>
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="@(Model.CurrentUserRole == "admin" ? 7 : 6)" class="text-center text-muted">
                                @(Model.CurrentUserRole == "admin" ? "днЮоГЩМЈЪ§Он" : "днЮоФуЕФГЩМЈЪ§Он")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- ЬэМгГЩМЈФЃЬЌПђЃЈНіЙмРэдБПЩМћЃЉ -->
        @if (Model.CurrentUserRole == "admin")
        {
            <div class="modal fade" id="addScoreModal" tabindex="-1" aria-labelledby="addScoreModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="addScoreModalLabel">ЬэМгГЩМЈ</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <form id="addScoreForm">
                                @Html.AntiForgeryToken()
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label for="addStudentId" class="form-label">бЇЩњ</label>
                                        <select class="form-select" id="addStudentId" name="AddStudentId" required>
                                            <option value="">ЧыбЁдёбЇЩњ</option>
                                            @if (Model.Students != null && Model.Students.Count > 0)
                                            {
                                                @foreach (var student in Model.Students)
                                                {
                                                    <option value="@student.StudentId">@student.StudentId - @student.Name</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="addCourseId" class="form-label">ПЮГЬ</label>
                                        <select class="form-select" id="addCourseId" name="AddCourseId" required>
                                            <option value="">ЧыбЁдёПЮГЬ</option>
                                            @if (Model.Courses != null && Model.Courses.Count > 0)
                                            {
                                                @foreach (var course in Model.Courses)
                                                {
                                                    <option value="@course.CourseId">@course.CourseId - @course.CourseName</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-12">
                                        <label for="addScoreValue" class="form-label">ГЩМЈ</label>
                                        <input type="number" class="form-control" id="addScoreValue" name="AddScoreValue" 
                                               required min="0" max="100" step="0.01" placeholder="0-100жЎМфЕФЪ§зж">
                                    </div>
                                </div>
                                <div class="mt-3">
                                    <button type="button" class="btn btn-primary w-100" onclick="submitAddScore()">ЬсНЛ</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <!-- БрМ­ГЩМЈФЃЬЌПђЃЈКЫаФаоИДЃКНіДЋЕнIDКЭГЩМЈжЕЃЉ -->
            <div class="modal fade" id="editScoreModal" tabindex="-1" aria-labelledby="editScoreModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="editScoreModalLabel">БрМ­ГЩМЈ</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <form id="editScoreForm">
                                @Html.AntiForgeryToken()
                                <!-- НіБЃСєГЩМЈIDКЭГЩМЈжЕЕФЬсНЛВЮЪ§ -->
                                <input type="hidden" id="hiddenScoreId" name="EditScoreId">
                                <div class="row g-3">
                                    <div class="col-md-12">
                                        <label for="editScoreValue" class="form-label">ГЩМЈ</label>
                                        <input type="number" class="form-control" id="editScoreValue" name="EditScoreValue" 
                                               required min="0" max="100" step="0.01" placeholder="0-100жЎМфЕФЪ§зж">
                                    </div>
                                </div>
                                <div class="mt-3">
                                    <button type="button" class="btn btn-primary w-100" onclick="submitEditScore()">ЬсНЛаоИФ</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- НХБОЧјЃЈКЫаФаоИДЃКБрМ­ТпМ­МђЛЏЃЉ -->
    <script>
        // ШЋОжГЃСП
        const baseUrl = '/ScoreManagement';
        const csrfToken = $('input[name="__RequestVerificationToken"]').val();
        const currentUserRole = '@Model.CurrentUserRole';

        // 1. ДђПЊБрМ­ФЃЬЌПђЃЈНіДЋЕнIDКЭГЩМЈжЕЃЉ
        function openEditModal(scoreId, scoreValue) {
            if (currentUserRole !== 'admin') return;

            // НіИГжЕIDКЭГЩМЈжЕЃЌЮобЇЩњ/ПЮГЬIDвРРЕ
            $('#hiddenScoreId').val(scoreId);
            $('#editScoreValue').val(scoreValue);
            
            // ЯдЪОФЃЬЌПђ
            $('#editScoreModal').modal('show');
        }

        // 2. ЬсНЛЬэМгГЩМЈЃЈБЃСєд­гаТпМ­ЃЉ
        function submitAddScore() {
            if (currentUserRole !== 'admin') return;

            // ЛёШЁБэЕЅЪ§Он
            const formData = $('#addScoreForm').serialize();
            const studentId = $('#addStudentId').val().trim();
            const courseId = $('#addCourseId').val().trim();
            const scoreValue = $('#addScoreValue').val().trim();

            // ЧАЖЫЛљДЁаЃбщ
            if (!studentId) {
                alert('ЧыбЁдёбЇЩњЃЁ');
                return;
            }
            if (!courseId) {
                alert('ЧыбЁдёПЮГЬЃЁ');
                return;
            }
            if (!scoreValue || scoreValue < 0 || scoreValue > 100) {
                alert('ГЩМЈБиаыЪЧ0-100жЎМфЕФгааЇЪ§зжЃЁ');
                return;
            }

            // AJAXЬсНЛ
            $.ajax({
                url: baseUrl,
                method: 'POST',
                data: formData,
                contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                success: function() {
                    alert('ГЩМЈЬэМгГЩЙІЃЁ');
                    $('#addScoreModal').modal('hide');
                    $('#addScoreForm')[0].reset();
                    window.location.reload();
                },
                error: function(jqXHR) {
                    const errorMsg = jqXHR.responseJSON || jqXHR.responseText || `ЬэМгЪЇАмЃК${jqXHR.statusText}`;
                    alert(`ЬэМгЪЇАмЃК${errorMsg}`);
                    console.log('ЬэМгГЩМЈДэЮѓЯъЧщЃК', jqXHR);
                }
            });
        }

        // 3. ЬсНЛБрМ­ГЩМЈЃЈКЫаФаоИДЃКНіЬсНЛIDКЭГЩМЈжЕЃЉ
        function submitEditScore() {
            if (currentUserRole !== 'admin') return;

            // ЛёШЁБэЕЅЪ§ОнЃЈНіIDКЭГЩМЈжЕЃЉ
            const formData = $('#editScoreForm').serialize();
            const scoreId = $('#hiddenScoreId').val().trim();
            const scoreValue = $('#editScoreValue').val().trim();

            // ЧАЖЫЛљДЁаЃбщ
            if (!scoreId) {
                alert('ГЩМЈIDЮоаЇЃЁ');
                return;
            }
            if (!scoreValue || scoreValue < 0 || scoreValue > 100) {
                alert('ГЩМЈБиаыЪЧ0-100жЎМфЕФгааЇЪ§зжЃЁ');
                return;
            }

            // AJAXЬсНЛ
            $.ajax({
                url: baseUrl,
                method: 'POST',
                data: formData,
                contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                success: function() {
                    alert('ГЩМЈБрМ­ГЩЙІЃЁ');
                    $('#editScoreModal').modal('hide');
                    window.location.reload();
                },
                error: function(jqXHR) {
                    const errorMsg = jqXHR.responseJSON || jqXHR.responseText || `БрМ­ЪЇАмЃК${jqXHR.statusText}`;
                    alert(`БрМ­ЪЇАмЃК${errorMsg}`);
                    console.log('БрМ­ГЩМЈДэЮѓЯъЧщЃК', jqXHR);
                }
            });
        }

        // 4. ЩОГ§ГЩМЈЃЈБЃСєд­гаТпМ­ЃЉ
        function deleteScore(scoreId) {
            if (currentUserRole !== 'admin') return;
            if (!scoreId || scoreId <= 0) {
                alert('ГЩМЈIDЮоаЇЃЁ');
                return;
            }

            // ШЗШЯЩОГ§
            if (confirm(`ШЗЖЈЩОГ§ГЩМЈIDЁО${scoreId}ЁПЕФМЧТМТ№ЃП`)) {
                $.ajax({
                    url: baseUrl,
                    method: 'POST',
                    data: {
                        __RequestVerificationToken: csrfToken,
                        DeleteScoreId: scoreId
                    },
                    contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                    success: function() {
                        alert('ГЩМЈЩОГ§ГЩЙІЃЁ');
                        window.location.reload();
                    },
                    error: function(jqXHR) {
                        const errorMsg = jqXHR.responseJSON || jqXHR.responseText || `ЩОГ§ЪЇАмЃК${jqXHR.statusText}`;
                        alert(`ЩОГ§ЪЇАмЃК${errorMsg}`);
                        console.log('ЩОГ§ГЩМЈДэЮѓЯъЧщЃК', jqXHR);
                    }
                });
            }
        }
    </script>
</body>
</html>