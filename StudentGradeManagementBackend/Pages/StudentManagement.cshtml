@page
@model StudentGradeManagementBackend.Pages.StudentManagementModel
@{
    ViewData["Title"] = "学生管理";
    // 权限控制：仅管理员可访问
    if (HttpContext.Session.GetString("Role") != "admin")
    {
        Response.Redirect("/Login");
    }
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <!-- Bootstrap 5 样式 -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Bootstrap 5 脚本 -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <!-- 导航栏 -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="#">学生成绩管理系统</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" 
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/Index">首页</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="#">学生管理</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="CourseManagement">课程管理</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="ScoreManagement">成绩管理</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="UserManagement">用户管理</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- 主内容区 -->
    <div class="container mt-4">
        <h1 class="text-center mb-4">学生管理</h1>
        
        <!-- 添加学生按钮 -->
        <button type="button" class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#addStudentModal">
            添加学生
        </button>

        <!-- 学生列表表格 -->
        <div class="table-responsive">
            <table class="table table-striped table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>学号</th>
                        <th>姓名</th>
                        <th>班级编号</th>
                        <th>院系编号</th>
                        <th>入学年份</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Students != null && Model.Students.Count > 0)
                    {
                        @foreach (var student in Model.Students)
                        {
                            <tr>
                                <td>@student.StudentId.Trim()</td>
                                <td>@student.Name.Trim()</td>
                                <td>@student.ClassId.Trim()</td>
                                <td>@student.DepartmentId.Trim()</td>
                                <td>@student.EnrollmentYear</td>
                                <td>
                                    <!-- 编辑按钮 -->
                                    <button type="button" class="btn btn-primary btn-sm me-2"
                                            onclick="openEditModal('@student.StudentId.Trim()', '@student.Name.Trim()', 
                                                                    '@student.ClassId.Trim()', '@student.DepartmentId.Trim()', 
                                                                    @student.EnrollmentYear)">
                                        编辑
                                    </button>
                                    <!-- 删除按钮 -->
                                    <button type="button" class="btn btn-danger btn-sm"
                                            onclick="deleteStudent('@student.StudentId.Trim()')">
                                        删除
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">暂无学生数据</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- 添加学生模态框 -->
        <div class="modal fade" id="addStudentModal" tabindex="-1" aria-labelledby="addStudentModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="addStudentModalLabel">添加学生（自动创建登录账号）</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <form id="addStudentForm">
                            @Html.AntiForgeryToken()
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="addStudentId" class="form-label">学号（登录账号）</label>
                                    <input type="text" class="form-control" id="addStudentId" name="AddStudentId" 
                                           required placeholder="如：2023065732" maxlength="10">
                                    <div class="form-text">学号将作为学生登录账号，不可重复</div>
                                </div>
                                <div class="col-md-6">
                                    <label for="addName" class="form-label">姓名</label>
                                    <input type="text" class="form-control" id="addName" name="AddName" 
                                           required placeholder="请输入学生姓名">
                                </div>
                                <div class="col-md-6">
                                    <label for="addClassId" class="form-label">班级</label>
                                    <select class="form-select" id="addClassId" name="AddClassId" required>
                                        <option value="">请选择班级</option>
                                        @if (Model.Classes != null && Model.Classes.Count > 0)
                                        {
                                            @foreach (var cls in Model.Classes)
                                            {
                                                <option value="@cls.ClassId">@cls.ClassId - @cls.ClassName</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label for="addDepartmentId" class="form-label">院系</label>
                                    <select class="form-select" id="addDepartmentId" name="AddDepartmentId" required>
                                        <option value="">请选择院系</option>
                                        @if (Model.Departments != null && Model.Departments.Count > 0)
                                        {
                                            @foreach (var dept in Model.Departments)
                                            {
                                                <option value="@dept.DepartmentId">@dept.DepartmentId - @dept.DepartmentName</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label for="addEnrollmentYear" class="form-label">入学年份</label>
                                    <input type="number" class="form-control" id="addEnrollmentYear" name="AddEnrollmentYear" 
                                           required min="2000" max="@DateTime.Now.Year" value="@DateTime.Now.Year">
                                </div>
                                <div class="col-md-6">
                                    <label for="addInitialPassword" class="form-label">初始密码</label>
                                    <input type="password" class="form-control" id="addInitialPassword" name="AddInitialPassword" 
                                           required placeholder="设置学生登录初始密码">
                                </div>
                            </div>
                            <div class="mt-3">
                                <button type="button" class="btn btn-primary w-100" onclick="submitAddStudent()">提交</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- 编辑学生模态框 -->
        <div class="modal fade" id="editStudentModal" tabindex="-1" aria-labelledby="editStudentModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="editStudentModalLabel">编辑学生信息</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <form id="editStudentForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" id="hiddenStudentId" name="EditStudentId">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">学号（不可修改）</label>
                                    <input type="text" class="form-control" id="showStudentId" readonly disabled>
                                </div>
                                <div class="col-md-6">
                                    <label for="editName" class="form-label">姓名</label>
                                    <input type="text" class="form-control" id="editName" name="EditName" required placeholder="请输入学生姓名">
                                </div>
                                <div class="col-md-6">
                                    <label for="editClassId" class="form-label">班级</label>
                                    <select class="form-select" id="editClassId" name="EditClassId" required>
                                        <option value="">请选择班级</option>
                                        @if (Model.Classes != null && Model.Classes.Count > 0)
                                        {
                                            @foreach (var cls in Model.Classes)
                                            {
                                                <option value="@cls.ClassId">@cls.ClassId - @cls.ClassName</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label for="editDepartmentId" class="form-label">院系</label>
                                    <select class="form-select" id="editDepartmentId" name="EditDepartmentId" required>
                                        <option value="">请选择院系</option>
                                        @if (Model.Departments != null && Model.Departments.Count > 0)
                                        {
                                            @foreach (var dept in Model.Departments)
                                            {
                                                <option value="@dept.DepartmentId">@dept.DepartmentId - @dept.DepartmentName</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-md-12">
                                    <label for="editEnrollmentYear" class="form-label">入学年份</label>
                                    <input type="number" class="form-control" id="editEnrollmentYear" name="EditEnrollmentYear" 
                                           required min="2000" max="@DateTime.Now.Year">
                                </div>
                            </div>
                            <div class="mt-3">
                                <button type="button" class="btn btn-primary w-100" onclick="submitEditStudent()">提交修改</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 脚本区 -->
    <script>
        // 全局常量
        const baseUrl = '/StudentManagement';
        const csrfToken = $('input[name="__RequestVerificationToken"]').val();

        // 1. 打开编辑模态框
        function openEditModal(studentId, name, classId, departmentId, enrollmentYear) {
            // 赋值到表单
            $('#hiddenStudentId').val(studentId);
            $('#showStudentId').val(studentId);
            $('#editName').val(name);
            $('#editClassId').val(classId);
            $('#editDepartmentId').val(departmentId);
            $('#editEnrollmentYear').val(enrollmentYear);
            
            // 显示模态框
            $('#editStudentModal').modal('show');
        }

        // 2. 提交添加学生
        function submitAddStudent() {
            // 获取表单数据
            const formData = $('#addStudentForm').serialize();
            const studentId = $('#addStudentId').val().trim();
            const initialPassword = $('#addInitialPassword').val().trim();

            // 前端基础校验
            if (!studentId) {
                alert('学号不能为空！');
                return;
            }
            if (!initialPassword) {
                alert('初始密码不能为空！');
                return;
            }

            // AJAX提交
            $.ajax({
                url: baseUrl,
                method: 'POST',
                data: formData,
                contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                success: function() {
                    alert(`学生${studentId}添加成功！\n登录账号：${studentId}\n初始密码：${initialPassword}`);
                    $('#addStudentModal').modal('hide');
                    $('#addStudentForm')[0].reset();
                    window.location.reload();
                },
                error: function(jqXHR) {
                    const errorMsg = jqXHR.responseJSON?.error || `添加失败：${jqXHR.statusText}`;
                    alert(errorMsg);
                }
            });
        }

        // 3. 提交编辑学生
        function submitEditStudent() {
            // 获取表单数据
            const formData = $('#editStudentForm').serialize();
            const studentId = $('#hiddenStudentId').val().trim();

            // 前端基础校验
            if (!studentId) {
                alert('学号无效！');
                return;
            }

            // AJAX提交
            $.ajax({
                url: baseUrl,
                method: 'POST',
                data: formData,
                contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                success: function() {
                    alert(`学生${studentId}编辑成功！`);
                    $('#editStudentModal').modal('hide');
                    window.location.reload();
                },
                error: function(jqXHR) {
                    const errorMsg = jqXHR.responseJSON?.error || `编辑失败：${jqXHR.statusText}`;
                    alert(errorMsg);
                }
            });
        }

        // 4. 删除学生
        function deleteStudent(studentId) {
            studentId = (studentId || '').trim();
            if (!studentId) {
                alert('学号不能为空！');
                return;
            }

            // 确认删除
            if (confirm(`确定删除学号【${studentId}】的学生吗？\n删除后将同步删除该学生的登录账号！`)) {
                $.ajax({
                    url: baseUrl,
                    method: 'POST',
                    data: {
                        __RequestVerificationToken: csrfToken,
                        DeleteStudentId: studentId
                    },
                    contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                    success: function() {
                        alert(`学生${studentId}删除成功！`);
                        window.location.reload();
                    },
                    error: function(jqXHR) {
                        const errorMsg = jqXHR.responseJSON?.error || `删除失败：${jqXHR.statusText}`;
                        alert(errorMsg);
                    }
                });
            }
        }
    </script>
</body>
</html>