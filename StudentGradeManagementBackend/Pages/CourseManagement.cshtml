@page
@model StudentGradeManagementBackend.Pages.CourseManagementModel
@{
    ViewData["Title"] = "课程管理";
    if (HttpContext.Session.GetString("Role")!= "admin")
    {
        Response.Redirect("/Login");
    }
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="#">学生成绩管理系统</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/Index">首页</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="StudentManagement">学生管理</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="#">课程管理</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="ScoreManagement">成绩管理</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="UserManagement">用户管理</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <h1 class="text-center mb-4">课程管理</h1>
        <button type="button" class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#addCourseModal">添加课程</button>
        
        <table class="table table-striped table-bordered" id="courseTable">
            <thead>
                <tr>
                    <th>课程编号</th>
                    <th>课程名称</th>
                    <th>学分</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Courses != null && Model.Courses.Count > 0)
                {
                    @foreach (var course in Model.Courses)
                    {
                        <!-- 核心修复：强制转字符串+去空格，确保data属性有值 -->
                        <tr>
                            <td>@course.CourseId.Trim()</td>
                            <td>@course.CourseName.Trim()</td>
                            <td>@course.Credit</td>
                            <td>
                                <button type="button" 
                                        class="btn btn-primary btn-sm edit-btn" 
                                        data-courseid="@(course.CourseId.Trim())" 
                                        data-coursename="@(course.CourseName.Trim())"
                                        data-credit="@course.Credit"
                                        onclick="openEditModal('@course.CourseId.Trim()', '@course.CourseName.Trim()', @course.Credit)">
                                    编辑
                                </button>
                                <button type="button" class="btn btn-danger btn-sm delete-btn" onclick="deleteCourse('@course.CourseId.Trim()')">删除</button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center">暂无课程数据</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- 添加课程模态框 -->
        <div class="modal fade" id="addCourseModal" tabindex="-1" aria-labelledby="addCourseModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="addCourseModalLabel">添加课程</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <form id="addCourseForm">
                            @Html.AntiForgeryToken()
                            <div class="form-group mb-3">
                                <label for="CourseId">课程编号</label>
                                <input type="text" class="form-control" id="CourseId" name="CourseId" required placeholder="如：2">
                            </div>
                            <div class="form-group mb-3">
                                <label for="CourseName">课程名称</label>
                                <input type="text" class="form-control" id="CourseName" name="CourseName" required placeholder="如：大学英语">
                            </div>
                            <div class="form-group mb-3">
                                <label for="Credit">学分</label>
                                <input type="number" step="0.1" min="0" class="form-control" id="Credit" name="Credit" required placeholder="如：3.0">
                            </div>
                            <button type="button" class="btn btn-primary" onclick="submitAddCourse()">提交</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- 编辑课程模态框 -->
        <div class="modal fade" id="editCourseModal" tabindex="-1" aria-labelledby="editCourseModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="editCourseModalLabel">编辑课程</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <!-- 隐藏域存储课程编号 -->
                        <input type="hidden" id="hiddenEditCourseId" value="">
                        <div class="form-group mb-3">
                            <label>课程编号（不可修改）</label>
                            <input type="text" class="form-control" id="showEditCourseId" readonly disabled>
                        </div>
                        <div class="form-group mb-3">
                            <label for="editCourseName">课程名称</label>
                            <input type="text" class="form-control" id="editCourseName" required placeholder="如：英语">
                        </div>
                        <div class="form-group mb-3">
                            <label for="editCredit">学分</label>
                            <input type="number" step="0.1" min="0" class="form-control" id="editCredit" required placeholder="如：4.5">
                        </div>
                        <button type="button" class="btn btn-primary" onclick="submitEditCourse()">提交修改</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // 全局变量存储CSRF令牌
        const token = $('input[name="__RequestVerificationToken"]').val();
        const baseUrl = '/CourseManagement';

        // 1. 打开编辑模态框（直接传参，不依赖data属性）
        function openEditModal(courseId, courseName, credit) {
            // 强制去空格，确保值不为空
            courseId = (courseId || '').trim();
            courseName = (courseName || '').trim();
            credit = credit || 0;

            console.log('编辑课程参数：', { courseId, courseName, credit });

            // 给隐藏域和只读框赋值
            $('#hiddenEditCourseId').val(courseId);
            $('#showEditCourseId').val(courseId);
            $('#editCourseName').val(courseName);
            $('#editCredit').val(credit);

            // 显示模态框
            $('#editCourseModal').modal('show');
        }

        // 2. 提交编辑课程
        function submitEditCourse() {
            // 获取值并强制去空格
            const courseId = $('#hiddenEditCourseId').val().trim();
            const courseName = $('#editCourseName').val().trim();
            const credit = $('#editCredit').val().trim();

            // 客户端前置校验
            if (!courseId) {
                alert('课程编号不能为空！');
                return;
            }
            if (!courseName) {
                alert('课程名称不能为空！');
                return;
            }
            if (!credit || isNaN(credit) || credit < 0) {
                alert('学分必须是大于等于0的数字！');
                return;
            }

            // 构建请求参数
            const formData = {
                __RequestVerificationToken: token,
                EditCourseId: courseId,
                EditCourseName: courseName,
                EditCredit: credit
            };

            // 发送请求
            $.ajax({
                url: baseUrl,
                method: 'POST',
                data: formData,
                success: function() {
                    alert('课程编辑成功！');
                    $('#editCourseModal').modal('hide');
                    window.location.reload();
                },
                error: function(jqXHR) {
                    const errorMsg = jqXHR.responseJSON?.error || jqXHR.statusText || '编辑失败';
                    alert(`编辑失败：${errorMsg}`);
                }
            });
        }

        // 3. 提交添加课程
        function submitAddCourse() {
            const courseId = $('#CourseId').val().trim();
            const courseName = $('#CourseName').val().trim();
            const credit = $('#Credit').val().trim();

            if (!courseId) { alert('课程编号不能为空！'); return; }
            if (!courseName) { alert('课程名称不能为空！'); return; }
            if (!credit || isNaN(credit) || credit < 0) { alert('学分必须是大于等于0的数字！'); return; }

            const formData = {
                __RequestVerificationToken: token,
                CourseId: courseId,
                CourseName: courseName,
                Credit: credit
            };

            $.ajax({
                url: baseUrl,
                method: 'POST',
                data: formData,
                success: function() {
                    alert('课程添加成功！');
                    $('#addCourseModal').modal('hide');
                    $('#addCourseForm')[0].reset();
                    window.location.reload();
                },
                error: function(jqXHR) {
                    const errorMsg = jqXHR.responseJSON?.error || jqXHR.statusText || '添加失败';
                    alert(`添加失败：${errorMsg}`);
                }
            });
        }

        // 4. 删除课程
        function deleteCourse(courseId) {
            courseId = (courseId || '').trim();
            if (!courseId) {
                alert('课程编号不能为空！');
                return;
            }

            if (confirm(`确定要删除课程【${courseId}】吗？`)) {
                const formData = {
                    __RequestVerificationToken: token,
                    DeleteCourseId: courseId
                };

                $.ajax({
                    url: baseUrl,
                    method: 'POST',
                    data: formData,
                    success: function() {
                        alert('课程删除成功！');
                        window.location.reload();
                    },
                    error: function(jqXHR) {
                        const errorMsg = jqXHR.responseJSON?.error || jqXHR.statusText || '删除失败';
                        alert(`删除失败：${errorMsg}`);
                    }
                });
            }
        }
    </script>
</body>
</html>